# ─────────────────────────────────────────────────────────────
#  BuyBites Backend — Environment Variables
#  Copy this file to .env and fill in real values
#  NEVER commit the real .env file to git
# ─────────────────────────────────────────────────────────────

PORT=5000

# MongoDB Atlas connection string
MONGO_URI=

# Paystack payment keys
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Peyflex VTU provider
PEYFLEX_BASE_URL=https://client.peyflex.com.ng
PEYFLEX_TOKEN=

# Admin API key (used on some routes as x-admin-key header)
ADMIN_KEY=

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRES=7d

# Termii SMS/WhatsApp OTP
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_SENDER_ID=BuyBites
TERMII_CHANNEL=dnd

# Seed admin on first startup (optional — remove after first run)
SEED_ADMIN_PHONE=
SEED_ADMIN_PIN=
SEED_ADMIN_NAME=BuyBites Admin

# Frontend URL for CORS and Paystack callback
FRONTEND_URL=http://localhost:5173
