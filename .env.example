# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/buybites

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES=7d

# ── Admin ────────────────────────────────────────────
ADMIN_KEY=your_admin_header_key
SEED_ADMIN_PHONE=2348012345678
SEED_ADMIN_PIN=123456
SEED_ADMIN_NAME=Admin

# ── CORS ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# For multiple: FRONTEND_URLS=https://app.buybites.com,https://staging.buybites.com

# ── Korapay (Wallet Funding) ──────────────────────────
KORAPAY_PUBLIC_KEY=pk_live_xxxx
KORAPAY_SECRET_KEY=sk_live_xxxx
KORAPAY_WEBHOOK_SECRET=your_webhook_hmac_secret

# ── Paystack (Alternative Payment) ───────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxx

# ── Peyflex (Data/Airtime Provider) ──────────────────
PEYFLEX_BASE_URL=https://api.peyflex.com
PEYFLEX_TOKEN=your_peyflex_token

# ── SMEData Provider ──────────────────────────────────
SMEDATA_BASE_URL=https://smeplug.ng
SMEDATA_API_KEY=your_smedata_key

# ── Termii (OTP/SMS) ──────────────────────────────────
TERMII_API_KEY=your_termii_key
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_WHATSAPP_FROM=BuyBites
TERMII_CHANNEL=generic

# ── Backend public URL (used in webhooks) ────────────
BACKEND_URL=https://buybites-backend.onrender.com
