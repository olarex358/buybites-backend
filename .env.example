# ─────────────────────────────────────────────────────────────
#  BuyBites Backend — Environment Variables
#  Copy this file to .env and fill in real values
#  NEVER commit the real .env file to git
# ─────────────────────────────────────────────────────────────

PORT=5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# MongoDB Atlas connection string
MONGO_URI=

# Korapay payment keys (Primary)
KORAPAY_PUBLIC_KEY=
KORAPAY_SECRET_KEY=
KORAPAY_WEBHOOK_SECRET=

# Paystack payment keys (Secondary)
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Peyflex VTU provider
PEYFLEX_BASE_URL=https://client.peyflex.com.ng
PEYFLEX_TOKEN=

# SMEData VTU provider
SMEDATA_BASE_URL=https://smedata.ng/wp-json/api/v1
SMEDATA_TOKEN=

# Admin API key (used on some routes as x-admin-key header)
ADMIN_KEY=

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRES=7d

# Termii SMS/WhatsApp OTP
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_SENDER_ID=BuyBites
TERMII_CHANNEL=generic

# Airtime to Cash settings
A2C_MTN_RATE=0.8
A2C_AIRTEL_RATE=0.75
A2C_GLO_RATE=0.75
A2C_9MOBILE_RATE=0.70
A2C_SEND_TO=070XXXXXX

# Seed admin on first startup (optional)
SEED_ADMIN_PHONE=
SEED_ADMIN_PIN=
SEED_ADMIN_NAME=BuyBites Admin
